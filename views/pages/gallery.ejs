<%- include('../partials/header') %>

<main class="container mt-5">
    <div class="row mb-1">
        <div class="col">
            <h1 class="display-4 fw-bold text-primary"><%= title %></h1>
            <p class="lead text-muted">A personal record of guiding expeditions across the historical pathways and sacred glacial peaks of Cusco.</p>
        </div>
    </div>
    
    <div class="row g-4 mb-5">
        
        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm">
                <img src="/images/gallery1.jpeg" alt="Group at the official Inka Trail start" class="card-img-top rounded img-fluid object-fit-cover" style="height: 250px;">
                <div class="card-body p-2 text-muted small italic">
                    <p class="mb-0">Expedition group at the Inka trail. Archive: Lourdes Soto.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm">
                <img src="/images/gallery2.jpg" alt="Ancient stone portal overlooking mountains" class="card-img-top rounded img-fluid object-fit-cover" style="height: 250px;">
                <div class="card-body p-2 text-muted small italic">
                    <p class="mb-0">Inti Punku Inka Site. Archive: Lourdes Soto.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm">
                <img src="/images/gallery3.jpeg" alt="Trekking group under the sun at a high alpine pass" class="card-img-top rounded img-fluid object-fit-cover" style="height: 250px;">
                <div class="card-body p-2 text-muted small italic">
                    <p class="mb-0"> Salkantay Pass. Archive: Lourdes Soto.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm">
                <img src="/images/gallery4.jpeg" alt="Lourdes Soto at a vibrant turquoise glacier lagoon" class="card-img-top rounded img-fluid object-fit-cover" style="height: 250px;">
                <div class="card-body p-2 text-muted small italic">
                    <p class="mb-0">The pristine waters of a glacial lagoon. Archive: Lourdes Soto.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm">
                <img src="/images/gallery5.jpg" alt="Trekker standing near a perfectly calm alpine lake" class="card-img-top rounded img-fluid object-fit-cover" style="height: 250px;">
                <div class="card-body p-2 text-muted small italic">
                    <p class="mb-0"> A mountain lake. Archive: Lourdes Soto.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 text-center">
            <div class="card h-100 border-0 shadow-sm">
                <img src="/images/gallery6.jpg" alt="Trekker admiring a massive snow-capped glacier peak" class="card-img-top rounded img-fluid object-fit-cover" style="height: 250px;">
                <div class="card-body p-2 text-muted small italic">
                    <p class="mb-0">The majestic, snow-capped heights of the Salkantay. Archive: Lourdes Soto.</p>
                </div>
            </div>
        </div>

    </div>
</main>

<%- include('../partials/footer') %>